{
  "name": "avocat-frontend",
  "version": "1.0.0",
  "homepage": "https://avocat.live",
  "description": "Lawyer office manager",
  "license": "MIT",
  "keywords": [
    "react",
    "vite",
    "bootstrap",
    "fullcalendar",
    "eslint"
  ],
  "main": "index.js",
  "repository": "https://github.com/ascoor/avocat-frontend",
  "author": "Askar <mr.askar1984@gmail.com>",
  "scripts": {
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.+(js|jsx)\"",
    "dev": "vite",
    "clean": "rm -rf build/",
    "build:dev": "npm run clean && vite build --mode development",
    "build:prod": "npm run clean && vite build --mode production",
    "purgecss": "purgecss --css src/**/*.css --content src/**/*.{html,js,jsx} --output src/purified/",
    "start:dev": "vite --mode development",
    "start:prod": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "serve": "vite preview",
    "analyze": "vite build --mode production && rollup-plugin-visualizer",
    "check:deps": "depcheck"
  },
  
  "dependencies": {
    "@ckeditor/ckeditor5-build-decoupled-document": "^40.2.0",
    "@ckeditor/ckeditor5-react": "^6.2.0",
    "@fullcalendar/core": "^6.1.9",
    "@fullcalendar/daygrid": "^6.1.9",
    "@fullcalendar/interaction": "^6.1.9",
    "@fullcalendar/react": "^6.1.9",
    "@fullcalendar/timegrid": "^6.1.9",
    "@popperjs/core": "^2.11.8",
    "@react-spring/web": "^9.7.3",
    "@vitejs/plugin-react": "^4.2.0",
    "animejs": "^3.2.2",
    "axios": "^1.5.0",
    "bootstrap": "^5.3.2",
    "boxicons": "^2.1.4",
    "date-fns": "^2.30.0",
    "docx": "^8.5.0",
    "docxtemplater": "^3.43.0",
    "file-saver": "^2.0.5",
    "mammoth": "^1.6.0",
    "moment": "^2.29.4",
    "path-browserify": "^1.0.1",
    "pizzip": "^3.1.4",
    "react": "^18.2.0",
    "react-big-calendar": "^1.8.2",
    "react-bootstrap": "^2.9.2",
    "react-datepicker": "^4.16.0",
    "react-dom": "^18.2.0",
    "react-draft-wysiwyg": "^1.15.0",
    "react-icons": "^4.12.0",
    "react-loader-spinner": "^6.1.6",
    "react-router-dom": "^6.2.1",
    "react-toastify": "^9.1.3",
    "scrollreveal": "^4.0.9",
    "vite": "^4.4.9"
  },
  "devDependencies": {
    "@babel/core": "^7.16.7",
    "@babel/preset-react": "^7.16.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@testing-library/react": "^14.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^8.4.1",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^27.2.4",
    "prettier": "^3.1.1",
    "purgecss": "^5.0.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "vite-plugin-compression": "^0.5.1"
  },
  "peerDependencies": {
    "@babel/core": "^7.16.7"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "not dead"
  ]
}
