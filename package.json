{
  "name": "avocat-frontend",
  "version": "1.0.0",
  "homepage": "https://avocat.live",
  "description": "Lawyer office manager",
  "license": "MIT",
  "keywords": [
    "react",
    "vite",
    "bootstrap",
    "fullcalendar",
    "eslint"
  ],
  "scripts": {
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.+(js|jsx)\"",
    "dev": "vite",
    "build": "vite build",
    "start": "node server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "serve": "vite preview"
  },
  "dependencies": {
    "@babel/core": "^7.0.0-bridge.0",
    "@fullcalendar/core": "^6.1.9",
    "@fullcalendar/daygrid": "^6.1.9",
    "@fullcalendar/interaction": "^6.1.9",
    "@fullcalendar/react": "^6.1.9",
    "@fullcalendar/timegrid": "^6.1.9",
    "@popperjs/core": "^2.11.8",
    "@react-spring/web": "^9.7.3",
    "@vitejs/plugin-react": "^4.2.0",
    "axios": "^1.5.0",
    "bootstrap": "^5.3.2",
    "date-fns": "^2.30.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "moment": "^2.29.4",
    "prop-types": "^15.8.1",
    "quill": "^1.3.7",
    "react": "^18.2.0",
    "react-big-calendar": "^1.8.2",
    "react-bootstrap": "^2.9.0",
    "react-bootstrap-icons": "^1.6.1",
    "react-datepicker": "^4.16.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.3.1",
    "react-loader-spinner": "^5.4.5",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.2.1",
    "vite": "^4.4.9",
    "web-vitals": "^3.4.0",
    "yup": "^1.2.0"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.22.15",
    "@testing-library/react": "^14.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3"
  },
  "main": "main.js",
  "repository": "https://github.com/ascoor/avocat-frontend",
  "author": "Askar <mr.askar1984@gmail.com>",
